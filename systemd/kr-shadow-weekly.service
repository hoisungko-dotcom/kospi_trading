[Unit]
Description=KR Shadow Strategy League — weekly league report (금 16:30 KST)
After=network.target

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/kospi_trading_system
ExecStart=/home/ubuntu/kospi_trading_system/venv/bin/python -m kospi_bot_v2.shadow.scripts.weekly_report
Environment=PYTHONUNBUFFERED=1
StandardOutput=journal
StandardError=journal
