# ──────────────────────────────────────────────────────────────
# KIS (한국투자증권) API 설정
# 발급처: https://securities.koreainvestment.com > 트레이딩 > Open API
# ──────────────────────────────────────────────────────────────

# 모의투자 여부 (처음에는 반드시 true로 시작하세요)
MOCK_TRADING=true

# 실전 계좌 (시세 조회 + 실전 주문에 사용)
KIS_APPKEY=여기에_실전_앱키_입력
KIS_APPSECRET=여기에_실전_앱시크릿_입력
KIS_ACCOUNT=여기에_계좌번호_입력  # 예: 12345678-01

# 모의 계좌 (MOCK_TRADING=true 일 때 주문에 사용, 시세는 실전 키 사용)
KIS_MOCK_APPKEY=여기에_모의_앱키_입력
KIS_MOCK_APPSECRET=여기에_모의_앱시크릿_입력
KIS_MOCK_ACCOUNT=여기에_모의_계좌번호_입력

# ──────────────────────────────────────────────────────────────
# 실전 거래 안전장치 (MOCK_TRADING=false 로 바꿀 때만 설정)
# ──────────────────────────────────────────────────────────────
LIVE_TRADING_CONFIRMED=false

# ──────────────────────────────────────────────────────────────
# 텔레그램 알림 (선택 사항)
# 발급: https://t.me/BotFather 에서 봇 생성
# ──────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=여기에_봇_토큰_입력
TELEGRAM_CHAT_ID=여기에_채팅_ID_입력

# ──────────────────────────────────────────────────────────────
# Claude AI 분석 (선택 사항 — 없어도 동작)
# 발급: https://console.anthropic.com
# ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=여기에_Anthropic_API_키_입력

# ──────────────────────────────────────────────────────────────
# 거래 파라미터 (기본값 사용 권장, 필요 시만 수정)
# ──────────────────────────────────────────────────────────────
# RISK_PER_TRADE=0.02          # 거래당 리스크 비율 (기본 2%)
# MAX_STRATEGY_POSITIONS=10    # 최대 보유 종목 수 (기본 10)
# DAILY_LOSS_LIMIT_PCT=-5.0    # 일일 손실 한도 % (기본 -5%)

# ──────────────────────────────────────────────────────────────
# 폭락 반등 예외 매수 (기본 보수 설정)
# ──────────────────────────────────────────────────────────────
# CRASH_RECOVERY_ENABLED=true
# CRASH_VIX_THRESHOLD=40
# CRASH_FEAR_GREED_THRESHOLD=15
# CRASH_RSI_THRESHOLD=20
# CRASH_VOLUME_SPIKE=3.0
# CRASH_SCORE_THRESHOLD=70
# CRASH_POSITION_PCT=0.10
# CRASH_MAX_DAILY_BUYS=1
# CRASH_STOCK_COOLDOWN_SEC=21600
# CRASH_BUY_UNTIL_HHMM=1450
# CRASH_REQUIRE_INTRADAY_CONFIRM=true
